# Backend .env example
# Copy to .env and fill in your API keys

# LLM Provider API Keys (only needed for providers you use)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=auto

# Database
DATABASE_URL=sqlite+aiosqlite:///./extraction.db

# File / artifact storage
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts
MAX_UPLOAD_SIZE_MB=50

# OCR engine feature flags (set to true to enable)
ENABLE_PADDLEOCR=false
ENABLE_GLM_OCR=false

# Local Ollama endpoint used by the GLM-OCR parser engine.
# GLM-OCR is a vision-language OCR model that runs entirely on your
# machine. Install Ollama (https://ollama.com) and pull the model:
#   ollama pull glm-ocr:latest
# Then set ENABLE_GLM_OCR=true to make it available in the parser dropdown.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GLM_OCR_MODEL=glm-ocr:latest
GLM_OCR_TIMEOUT_SECONDS=120

# Pipeline tuning (optional — defaults are sensible for most use cases)
# CONFIDENCE_THRESHOLD=0.6
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY=1.0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
