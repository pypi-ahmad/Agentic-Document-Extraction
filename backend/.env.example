# Backend .env example
# Copy to .env and fill in your API keys

# LLM Provider API Keys (only needed for providers you use)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=auto

# Database
DATABASE_URL=sqlite+aiosqlite:///./extraction.db

# File / artifact storage
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts
MAX_UPLOAD_SIZE_MB=50

# OCR engine feature flags (set to true to enable)
ENABLE_PADDLEOCR=false

# Pipeline tuning (optional — defaults are sensible for most use cases)
# CONFIDENCE_THRESHOLD=0.6
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY=1.0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
